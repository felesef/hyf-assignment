{
  "openapi": "3.0.0",
  "info": {
    "title": "User Database API",
    "version": "1.0.0",
    "description": "API for managing users in the database"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/all-users": {
      "get": {
        "summary": "Get all users",
        "description": "Returns all users sorted by ID",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/unconfirmed-users": {
      "get": {
        "summary": "Get unconfirmed users",
        "description": "Returns all users where confirmed_at is NULL",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "List of unconfirmed users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/gmail-users": {
      "get": {
        "summary": "Get Gmail users",
        "description": "Returns all users with @gmail.com email addresses",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "List of Gmail users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/2022-users": {
      "get": {
        "summary": "Get 2022 users",
        "description": "Returns all users created in 2022",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "List of users created in 2022",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/user-count": {
      "get": {
        "summary": "Get user count",
        "description": "Returns the total number of users in the database",
        "tags": ["Statistics"],
        "responses": {
          "200": {
            "description": "User count",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "COUNT(*)": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/last-name-count": {
      "get": {
        "summary": "Get count by last name",
        "description": "Returns the count of users with a specific last name",
        "tags": ["Statistics"],
        "parameters": [
          {
            "name": "lastName",
            "in": "query",
            "required": true,
            "description": "Last name to search for (case-insensitive)",
            "schema": {
              "type": "string"
            },
            "example": "Smith"
          },
          {
            "name": "lastname",
            "in": "query",
            "required": false,
            "description": "Alternative parameter name for last name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Count of users with the specified last name",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "count": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - lastName parameter is required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/first-user": {
      "get": {
        "summary": "Get first user",
        "description": "Returns the user with the lowest ID",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "First user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/last-user": {
      "get": {
        "summary": "Get last user",
        "description": "Returns the user with the highest ID",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "Last user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/add-user": {
      "post": {
        "summary": "Add a new user",
        "description": "Creates a new user in the database",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["first_name", "last_name", "email"],
                "properties": {
                  "first_name": {
                    "type": "string",
                    "example": "John"
                  },
                  "last_name": {
                    "type": "string",
                    "example": "Doe"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "john.doe@example.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/update-user": {
      "put": {
        "summary": "Update a user",
        "description": "Updates an existing user in the database",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "first_name", "last_name", "email"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "example": 1
                  },
                  "first_name": {
                    "type": "string",
                    "example": "Jane"
                  },
                  "last_name": {
                    "type": "string",
                    "example": "Smith"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "jane.smith@example.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/delete-user": {
      "delete": {
        "summary": "Delete a user",
        "description": "Deletes a user from the database",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "example": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "User deleted successfully"
          },
          "400": {
            "description": "Bad request - id is required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2022-03-15T10:22:00"
          },
          "confirmed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "first_name": {
            "type": "string",
            "example": "John"
          },
          "last_name": {
            "type": "string",
            "example": "Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john.doe@example.com"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Error message"
          }
        }
      }
    }
  }
}

